#!/usr/bin/env zsh
#
# aural-dictate — speak, and get the text on your clipboard.
#
# Captures the microphone for a few seconds, transcribes it, and copies the
# resulting text to the macOS clipboard (pbcopy) so you can paste it anywhere.
#
# Usage:
#   aural-dictate            # 30 seconds (default)
#   aural-dictate 10         # 10 seconds
#
# Environment:
#   AURAL_DICTATE_SECONDS    default capture length when no argument is given (default: 30)
#   AURAL_ENGINE/...         any AURAL_* var Aural honors (engine, model, language…)
#
# Requirements: `aural`, `pbcopy` (macOS), and microphone permission.

set -euo pipefail

die() { print -u2 -- "aural-dictate: $*"; exit 1 }

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { sed -n '2,18p' "$0"; exit 0 }

command -v aural  >/dev/null 2>&1 || die "missing dependency: aural"
command -v pbcopy >/dev/null 2>&1 || die "missing dependency: pbcopy"

secs="${1:-${AURAL_DICTATE_SECONDS:-30}}"
[[ "$secs" == <1-> ]] || die "duration must be a positive integer number of seconds (got '$secs')"

print -u2 -- "aural-dictate: listening for ${secs}s…"

# Transcript to stdout ('-'); piping to pbcopy makes stdout a pipe (not a TTY),
# so this is a plain non-interactive capture.
text=$(aural --duration "$secs" -t -)
print -rn -- "$text" | pbcopy

words=$(print -rn -- "$text" | wc -w | tr -d ' ')
print -u2 -- "aural-dictate: copied $words word(s) to the clipboard."
